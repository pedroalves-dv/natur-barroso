# =============================================================================
# Natur Barroso — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.
#
# NEXT_PUBLIC_* vars are bundled into the browser. All others are server-only.
# =============================================================================


# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------

# Canonical origin — used for absolute URLs in metadata, sitemaps, and OG tags.
NEXT_PUBLIC_SITE_URL=https://naturbarroso.pt


# -----------------------------------------------------------------------------
# Sanity (CMS) — Phase 4
# https://www.sanity.io/manage
# -----------------------------------------------------------------------------

# Project ID and dataset are safe to expose; they identify the project publicly.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# API version: pin to the date you first integrate (format: YYYY-MM-DD).
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Server-only token with "Editor" or "Viewer" role.
# Create at: sanity.io/manage → API → Tokens.
# Used for server-side data fetching and webhook signature verification.
SANITY_API_TOKEN=your_sanity_api_token

# Secret for verifying Sanity webhook payloads (revalidation on content publish).
# Generate a random string: `openssl rand -base64 32`
SANITY_WEBHOOK_SECRET=your_webhook_secret


# -----------------------------------------------------------------------------
# FareHarbor (Booking) — Phase 4
# https://fareharbor.com/help/
# -----------------------------------------------------------------------------

# Your company's FareHarbor shortname (appears in your FareHarbor dashboard URL).
# Safe to expose — it's embedded in the public booking widget script.
NEXT_PUBLIC_FAREHARBOR_SHORTNAME=naturbarroso


# -----------------------------------------------------------------------------
# Resend (Transactional Email) — Phase 5
# https://resend.com/api-keys
# -----------------------------------------------------------------------------

# Server-only API key — never expose this to the browser.
RESEND_API_KEY=re_your_api_key

# Verified "from" address for outbound emails (must match a domain verified in Resend).
RESEND_FROM_EMAIL=hello@naturbarroso.pt

# Internal address where contact form submissions are delivered.
CONTACT_EMAIL_TO=info@naturbarroso.pt


# -----------------------------------------------------------------------------
# Mapbox (Maps) 
# https://account.mapbox.com/access-tokens/
# -----------------------------------------------------------------------------

# Public token — safe to expose. Restrict it to your domain in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token


# -----------------------------------------------------------------------------
# Google Analytics 4 — Phase 6
# https://analytics.google.com/ → Admin → Data Streams → Measurement ID
# -----------------------------------------------------------------------------

# Measurement ID (format: G-XXXXXXXXXX). Safe to expose — it's in the page HTML.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
